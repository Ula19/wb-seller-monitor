# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Telegram ID владельца (админа). Узнать свой ID можно у @userinfobot
OWNER_ID=123456789

# Подключение к Postgres (внутри docker-compose хост = db)
DATABASE_URL=postgresql+asyncpg://wb:wb@db:5432/wb

# Интервал проверки новинок, минут
MONITOR_INTERVAL_MINUTES=10
# Интервал для приоритетных магазинов (кнопка ⚡ Ежеминутные), минут
FAST_MONITOR_INTERVAL_MINUTES=1
# Сколько товаров в магазине, чтобы слать отчёт Excel-файлом вместо текста
BIG_SHOP_THRESHOLD=100

# Минимальное изменение цены в % для уведомления (мелкие колебания игнорируются)
PRICE_CHANGE_THRESHOLD_PCT=5

# Наша цена = цена ВБ минус этот процент
OUR_DISCOUNT_PCT=15

# Наценка от личной business-цены (detail с кукой) до витринной «с WB Кошельком».
# Аккаунт бизнесовый → detail отдаёт цену НИЖЕ витрины; на сайте она ~2.73% выше.
# Розница = business_product + этот %. Плоский (SPP аккаунта плоский). 0 = не применять.
WB_RETAIL_MARKUP_PCT=2.73

# Троттлинг запросов к WB. WB банит за ТЕМП: безопасно ≤~100 req/час, паузы 3-7с.
# Меньше этих значений = риск 403 и бана IP. Без прокси не уменьшай.
REQUEST_MIN_DELAY=3.0
REQUEST_JITTER=4.0

# Кука авторизованного аккаунта WB (нужна для b2b-цен). Вся строка Cookie из браузера.
# Протухает за дни — обновлять вручную. Пусто = ходим без авторизации.
WB_COOKIE=

# 1 = брать бизнес-цены (b2b) вместо розничных. Требует валидную WB_COOKIE.
WB_B2B=1

# Заголовки для b2b-эндпоинта __internal (без них WB отдаёт 403 даже с кукой).
# Если b2b начал давать 403 — обнови WB_SPA_VERSION (значение видно в заголовке
# x-spa-version любого запроса в DevTools). deviceid обычно менять не нужно.
WB_DEVICE_ID=site_a5d186ace2fe4386952d1652f6a28303
WB_SPA_VERSION=14.16.0

# Прокси к WB. WB отдаёт 403 на не-РФ и дата-центровые IP — нужен РОССИЙСКИЙ
# резидентный/мобильный прокси. Один или список через запятую; на 403 бот переключается
# на следующий. Пусто = напрямую. Примеры:
#   WB_PROXIES=socks5h://1.2.3.4:1080
#   WB_PROXIES=http://user:pass@gate.provider.com:8000
WB_PROXIES=

# Дебаг: 1 = логировать сырой JSON первого товара (смотрим все поля API). Потом выключить.
DEBUG_RAW=0
